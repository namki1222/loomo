#!/bin/bash
# tell — session-to-session messaging bridge for Claude Code over tmux
#
# 메시징:
#   tell <세션> <역할> "<메시지>"        요청 전송 (6자리 상관키 KEY 자동 생성·출력)
#   tell -r <KEY> <세션> <역할> "<메시지>"  응답 전송 (받은 요청의 KEY 그대로)
# 관리:
#   tell ws [<세션>]                     워크스페이스 부트스트랩/접속 (설정: workspaces.conf)
#   tell up <세션> | --all [--tabs]      켜기 — 하나만 / 전체(허브 접속) · 인자 없으면 무엇을 켤지 안내
#   tell down <세션>|--all               끄기 — 세션 종료만, 설정은 유지
#   tell layout [<세션>] <프리셋>          패널 배치 변경 — tiled/main-vertical 등 (tmux.conf 불필요)
#   tell init                            셋업 마법사 — 허브(선택) → 프로젝트/역할/디렉터리
#   tell adopt                           쓰던 Claude 가져오기 — 떠 있는 패널 편입 + 기존 대화(세션ID) 이어받기
#   tell hub                             총괄 관리(허브) 세션 등록 (허브는 시스템 전체에 하나만)
#   tell list                            주소록 — 말 걸 수 있는 세션:역할 + 규약 여부
#   tell rm <세션>                       워크스페이스 삭제 — 종료+설정+규약 블록 제거 (프로젝트 파일 무손상)
#   tell doctor                          환경 점검
#   tell completion                      셸 자동완성 스크립트 — .zshrc에 eval "$(tell completion)"
#   tell help                            전체 명령·설명 (인자 없이 tell만 쳐도 표시)
#
# 동작 원리:
#   - 대상 = tmux "세션 이름" + "패널 제목(=역할)". 메시지는 send-keys로 상대 입력창에 직접 입력됨.
#   - 요청 헤더: [세션 요청 - KEY from 보낸세션/보낸역할]  /  응답 헤더: [세션 응답 - KEY from ...]
#   - 받는 쪽 Claude는 CLAUDE.md 규약(templates/ 참고)에 따라 작업 후 `tell -r KEY ...`를 실행해 응답.
#   - 대상이 작업 중이어도 전송됨(Claude Code가 입력을 큐잉). 입력창에 미제출 텍스트가 있으면
#     덮어쓰기 방지를 위해 10초 대기 후 재시도(최대 3회).
#
# ⚠️ 보안: send-keys 기반이라 같은 tmux 서버 사용자는 누구나 주입 가능. 비밀번호/토큰은 절대 tell로 보내지 말 것.
# 종료코드: 0 전송 / 1 대상없음 / 2 인자오류

set -u
# 설정 경로: TELL_CONFIG_DIR 우선 · 기본은 ~/.config/loomo · 단 기존 claude-tell-bridge만 있으면 그걸 씀(하위호환)
CONFIG_DIR="${TELL_CONFIG_DIR:-}"
if [ -z "$CONFIG_DIR" ]; then
  if [ -d "$HOME/.config/claude-tell-bridge" ] && [ ! -d "$HOME/.config/loomo" ]; then
    CONFIG_DIR="$HOME/.config/claude-tell-bridge"
  else
    CONFIG_DIR="$HOME/.config/loomo"
  fi
fi
WS_CONF="$CONFIG_DIR/workspaces.conf"
HUB_FILE="$CONFIG_DIR/hub"   # 허브 포인터 '세션|역할' — 허브는 시스템 전체에 하나만

# ── 에이전트 프로필 ────────────────────────────────────────────────────────────
# 코어(send-keys 통신)는 에이전트 무관. 아래 5개 값만 에이전트별로 다르다.
# loomo 하나가 claude·codex 둘 다 지원 — 전역 기본 + 패널별 오버라이드(workspaces.conf 5번째 필드).
TELL_AGENT="${TELL_AGENT:-${TELL_DEFAULT_AGENT:-claude}}"
load_agent_profile() { # $1=에이전트(claude|codex) → 전역 AGENT_* 를 그 에이전트 값으로 설정
  case "${1:-claude}" in
    codex) AGENT_CMD="codex"; AGENT_CONV="AGENTS.md"; AGENT_PROMPT="›"; AGENT_SESSIONS="$HOME/.codex/sessions"; AGENT_LABEL="Codex" ;;
    *)     AGENT_CMD="claude"; AGENT_CONV="CLAUDE.md"; AGENT_PROMPT="❯"; AGENT_SESSIONS="$HOME/.claude/projects"; AGENT_LABEL="Claude Code" ;;
  esac
}
load_agent_profile "$TELL_AGENT"   # 전역 기본 로드

agent_of() { # $1=세션 $2=역할 → 그 패널의 에이전트(conf 5번째 필드). 없으면 전역 기본
  local a=""
  [ -f "$WS_CONF" ] && a=$(grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" 2>/dev/null | LC_ALL=C awk -F'|' -v s="$1" -v r="$2" '$1==s && $2==r{print $5; exit}')
  printf '%s' "${a:-$TELL_AGENT}"
}

agent_launch() { # $1=에이전트  $2=resume_id(선택) → 패널에서 실행할 명령. exec로 셸 대체(종료 시 패널 정리)
  local ag="${1:-claude}" rid="${2:-}"
  # codex: tell 통신은 tmux 소켓(다른 세션 조회/주입)을 쓰므로 sandbox를 풀어야 함 — 기본 sandbox는 이를 차단
  local cx_opt="--sandbox danger-full-access"
  if [ -n "$rid" ]; then
    case "$ag" in
      codex) printf 'exec codex %s resume %s' "$cx_opt" "$rid" ;;   # codex: 서브커맨드
      *)     printf 'exec claude --resume %s' "$rid" ;;             # claude: 플래그
    esac
  else
    case "$ag" in codex) printf 'exec codex %s' "$cx_opt" ;; *) printf 'exec claude' ;; esac
  fi
}

# ── 스크립트 실제 위치(심링크 해제) → templates/ 찾기 ──────────────────────────
resolve_self() {
  local src="$0"
  while [ -L "$src" ]; do
    local dir; dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}
SELF_DIR=$(resolve_self)
TEMPLATE_DIR="$SELF_DIR/../templates"
BRAND="${TELL_BRAND:-loomo}"   # 브랜드명 (배너/도움말) — AGENT_LABEL은 load_agent_profile이 설정

# ── CLI UI 킷 (컬러는 TTY에서만, NO_COLOR 존중) ────────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_B=$'\033[1m'; C_D=$'\033[2m'; C_C=$'\033[36m'; C_G=$'\033[32m'; C_Y=$'\033[33m'; C_R=$'\033[31m'; C_X=$'\033[0m'
else
  C_B=""; C_D=""; C_C=""; C_G=""; C_Y=""; C_R=""; C_X=""
fi
banner() {
  echo ""
  echo "${C_C}${C_B}════════════════════════════════════════════════════${C_X}"
  echo "${C_C}${C_B}   🔗 $BRAND — $1${C_X}"
  echo "${C_C}${C_B}════════════════════════════════════════════════════${C_X}"
}
step() { echo ""; echo "${C_Y}${C_B}▶ $1${C_X}"; }
note() { echo "${C_D}  $1${C_X}"; }
ok()   { echo "${C_G}  ✔ $1${C_X}"; }
skip() { echo "${C_D}  ⤼ $1${C_X}"; }
warn() { echo "${C_R}  ⚠ $1${C_X}"; }
ask()  { printf "%s" "${C_B}$1${C_X}"; }
abspath() { # ~ 확장 + 상대경로 → 절대경로 (실행 위치가 달라도 설정이 항상 유효하도록)
  local d="$1"; d=${d/#\~/$HOME}
  case "$d" in ""|/*) ;; *) d="$PWD/$d" ;; esac
  printf '%s' "$d"
}

# ══════════════════════════════════════════════════════════════════════════════
# 서브커맨드
# ══════════════════════════════════════════════════════════════════════════════

cmd_help() {
  local V; V=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$SELF_DIR/../package.json" 2>/dev/null | head -1)
  row() { printf "  ${C_C}%-12s${C_X} %s\n" "$1" "$2"; }
  banner "help${V:+ · v$V}"
  echo ""
  echo "  여러 AI 세션(Claude Code·Codex)을 엮어, 서로 대화하는 하나의 팀으로."
  echo "  ${C_D}세션 = 프로젝트 팀 · 패널(역할) = 그 팀에 상주하는 AI 하나${C_X}"
  echo "  ${C_D}세션끼리의 메시징은 규약에 따라 AI가 알아서 주고받는다 — 사람은 자연어로 시키면 된다.${C_X}"
  echo ""
  echo "${C_Y}${C_B}세팅${C_X}"
  row "init"       "셋업 마법사 — 허브(선택) → 프로젝트/역할/디렉터리 등록 + 규약 자동 삽입"
  row "adopt"      "쓰던 AI 가져오기 — 떠 있는 패널 편입, 기존 대화는 세션ID로 이어받기"
  row "hub"        "총괄 관리(허브=비서) 세션 등록 — 시스템 전체에 하나만"
  echo ""
  echo "${C_Y}${C_B}운영${C_X}"
  row "up"         "켜기 — up <세션>(하나) / up --all(전체→허브 접속, +--tabs 탭) / up(목록 안내)"
  row "down"       "끄기 — loomo down <세션> / down --all (설정은 유지)"
  row "layout"     "패널 배치 — loomo layout [<세션>] <프리셋> (tiled/main-vertical 등, tmux.conf 불필요)"
  row "ws"         "세션 하나 띄우기/접속 — loomo ws <세션> (인자 없으면 목록)"
  row "list"       "주소록 — 지금 말 걸 수 있는 세션:역할 + 연결·실행 상태"
  row "rm"         "워크스페이스 삭제 — 종료+설정+규약 블록 제거 (프로젝트 파일 무손상)"
  echo ""
  echo "${C_Y}${C_B}진단·편의${C_X}"
  row "doctor"     "환경 점검 — tmux·claude·설정·허브·패키지 리소스"
  row "completion" "탭 자동완성 — .zshrc에 eval \"\$(loomo completion)\" 한 줄"
  row "help"       "이 도움말"
  echo ""
  echo "${C_Y}${C_B}시작하기${C_X}"
  echo "  ${C_D}loomo init → loomo up --all → 아무 패널의 AI에게: \"web한테 스키마 바뀐 거 알려줘\"${C_X}"
  echo "  ${C_D}문서: https://github.com/namki1222/loomo${C_X}"
}

cmd_doctor() {
  local ok=0
  banner "doctor · 환경 점검"
  if command -v tmux >/dev/null 2>&1; then echo "✅ tmux $(tmux -V | awk '{print $2}')"; else echo "❌ tmux 없음 — brew install tmux"; ok=1; fi
  if command -v "$AGENT_CMD" >/dev/null 2>&1; then echo "✅ $AGENT_CMD $("$AGENT_CMD" --version 2>/dev/null | awk '{print $1}')"; else echo "⚠️  $AGENT_CMD CLI 없음 — 메시징은 되지만 받는 쪽 AI가 없음"; fi
  if [ -n "${TMUX:-}" ]; then echo "✅ tmux 세션 안에서 실행 중 (발신자 헤더 자동)"; else echo "ℹ️  tmux 밖 — 발신자(from) 헤더 없이 전송됨"; fi
  if [ -f "$WS_CONF" ]; then echo "✅ 워크스페이스 설정: $WS_CONF ($(grep -cvE '^[[:space:]]*(#|$)' "$WS_CONF" 2>/dev/null || echo 0)줄)"; else echo "ℹ️  워크스페이스 설정 없음 — 'tell init' 또는 'tell adopt'로 생성"; fi
  if get_hub; then echo "✅ 허브: $HUB · $HUBR (허브는 하나만)"; else echo "ℹ️  허브 없음 — 'tell hub'로 등록 (선택)"; fi
  [ -f "$TEMPLATE_DIR/CLAUDE-section-role.md" ] && echo "✅ 패키지 리소스 정상" || echo "⚠️  패키지 손상 — 'npm i -g loomo' 재설치 필요"
  return $ok
}

# 세션 간 응답 연결 설정 (내부 동작 — 출력은 조용히, 사용자에겐 '패널 추가/편입 완료'로만 보임)
append_role_template() { # $1=dir  $2=session  $3=roles(공백구분)  $4=hub_session  $5=hub_role
  local dir="$1" session="$2" roles="$3" hub_s="$4" hub_r="$5"
  local f="$dir/$AGENT_CONV" t="$TEMPLATE_DIR/CLAUDE-section-role.md"
  [ -f "$t" ] || { warn "설치 손상 — 'npm i -g loomo' 재설치 필요"; return 1; }
  if [ -f "$f" ] && grep -q '세션 요청 - KEY' "$f" 2>/dev/null; then
    return 0   # 이미 연결돼 있음 — 조용히 통과
  fi
  mkdir -p "$dir"
  { [ -f "$f" ] && echo ""; sed -e "s/{{SESSION}}/$session/g" -e "s/{{ROLES}}/$roles/g" \
        -e "s/{{HUB_SESSION}}/$hub_s/g" -e "s/{{HUB_ROLE}}/$hub_r/g" "$t" \
    | sed -e 's# (보통 발신자는 허브 `/`)##'; } >> "$f"   # 허브 없이 쓰면 허브 문구 제거
  return 0
}

list_agent_sessions() { # $1=dir — 그 디렉터리에서 쓰던 대화 목록(최근 5개). 있으면 0
  local lines="" f id
  if [ "$TELL_AGENT" = "codex" ]; then
    # codex: 날짜폴더 전체에서 cwd가 $1인 세션 파일을 찾음 (파일명 uuid = 세션ID)
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      grep -qF "\"cwd\":\"$1\"" "$f" 2>/dev/null || continue
      id=$(basename "$f" .jsonl | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' | head -1)
      lines="$lines    $id  ${C_D}(마지막 사용: $(date -r "$f" '+%m/%d %H:%M' 2>/dev/null))${C_X}
"
      [ "$(printf '%s' "$lines" | grep -c '.')" -ge 5 ] && break
    done <<EOF
$(ls -t "$AGENT_SESSIONS"/*/*/*/*.jsonl 2>/dev/null | head -60)
EOF
  else
    # claude: 디렉터리 슬러그 폴더의 jsonl (파일명 = 세션ID)
    local proj="$AGENT_SESSIONS/$(printf '%s' "$1" | sed 's/[^A-Za-z0-9]/-/g')"
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      lines="$lines    $(basename "$f" .jsonl)  ${C_D}(마지막 사용: $(date -r "$f" '+%m/%d %H:%M' 2>/dev/null))${C_X}
"
    done <<EOF
$(ls -t "$proj"/*.jsonl 2>/dev/null | head -5)
EOF
  fi
  [ -n "$lines" ] || return 1
  note "이 디렉터리에서 쓰던 최근 $TELL_AGENT 대화:"
  printf '%s' "$lines"
  return 0
}

ask_resume_id() { # $1=dir — 이어받을 대화 세션ID를 물어봄. 결과는 전역 RID (빈 값 = 새 대화)
  RID=""
  list_agent_sessions "$1" || return 0
  # /dev/tty 고정: adopt의 파이프 루프 안에서도 사용자 입력을 받기 위함 (마법사는 대화형 전용)
  ask "  이어받을 대화 세션ID (엔터 = 새 대화로 시작): "; read -r RID </dev/tty
}

dir_from_session_id() { # $1=세션ID → 대화 기록(jsonl)의 cwd에서 담당 디렉터리 역추적. 성공 시 stdout
  local f
  if [ "$TELL_AGENT" = "codex" ]; then
    f=$(ls "$AGENT_SESSIONS"/*/*/*/*"$1"*.jsonl 2>/dev/null | head -1)   # 날짜폴더 + 파일명에 uuid
  else
    f=$(ls "$AGENT_SESSIONS"/*/"$1".jsonl 2>/dev/null | head -1)          # 슬러그폴더 + 파일명=uuid
  fi
  [ -n "$f" ] || return 1
  grep -o '"cwd":"[^"]*"' "$f" 2>/dev/null | head -1 | sed 's/^"cwd":"//; s/"$//'
}

get_hub() { # 등록된 허브 로드 → HUB/HUBR 설정. 없으면 1
  HUB=""; HUBR=""
  [ -f "$HUB_FILE" ] || return 1
  IFS='|' read -r HUB HUBR < "$HUB_FILE"
  [ -n "$HUB" ] || return 1
  HUBR=${HUBR:-$HUB}
  return 0
}

make_hub() { # 허브 세션 등록 + 허브 CLAUDE.md 생성. 성공 시 HUB/HUBR 설정됨 (허브는 단일 패널 → 이름=역할)
  if get_hub; then # 허브는 하나만 — 이미 있으면 새로 만들지 않는다
    warn "허브는 하나만 둘 수 있습니다 — 이미 '$HUB · $HUBR' 이 허브입니다 (교체: tell rm $HUB 후 tell hub)"
    return 1
  fi
  ask "  허브 이름 [hub]: "; read -r HUB; HUB=${HUB:-hub}; HUBR="$HUB"
  # read -e: 경로 입력 중 탭(파일명) 완성
  ask "  허브 작업 디렉터리 [~/tell-hub]: "; read -e -r HUBD; HUBD=$(abspath "${HUBD:-$HOME/tell-hub}")
  ask_resume_id "$HUBD"
  echo "$HUB|$HUBR|$HUBD|$RID" >> "$WS_CONF"; mkdir -p "$HUBD"
  echo "$HUB|$HUBR" > "$HUB_FILE"
  if [ -f "$TEMPLATE_DIR/CLAUDE-section-hub.md" ] && ! grep -q '허브(비서)' "$HUBD/$AGENT_CONV" 2>/dev/null; then
    { [ -f "$HUBD/$AGENT_CONV" ] && echo ""; sed -e "s/{{HUB_SESSION}}/$HUB/g" -e "s/{{HUB_ROLE}}/$HUBR/g" "$TEMPLATE_DIR/CLAUDE-section-hub.md"; } >> "$HUBD/$AGENT_CONV"
  fi
  ok "허브 구성 완료 — ${C_B}$HUB · $HUBR${C_X}"
}

cmd_init() {
  banner "init · 셋업 마법사"
  note "개념: 세션 = 프로젝트 / 패널(역할) = 그 프로젝트에 상주하는 AI 하나"
  note "언제든 Ctrl+C 로 종료할 수 있습니다 — 그때까지 입력한 내용은 저장됩니다."
  mkdir -p "$CONFIG_DIR"
  trap 'echo ""; ok "지금까지 입력분 저장됨: $WS_CONF   (이어서: tell init / 확인: tell list)"; exit 0' INT
  step "기본 AI 모델"
  note "이 워크스페이스에서 주로 쓸 AI. 세션(패널)마다 다르게도 지정할 수 있습니다 (claude·codex 혼합 가능)."
  ask "기본 모델 [claude / codex, 엔터=claude]: "; read -r DEFAG
  case "$DEFAG" in codex) DEFAG=codex ;; *) DEFAG=claude ;; esac
  ok "기본 모델: ${C_B}$DEFAG${C_X}"
  step "[1/2] 총괄 관리(허브) 세션 — 선택사항"
  if get_hub; then # 허브는 하나만 — 이미 있으면 그대로 쓰고 프로젝트 등록으로 넘어간다
    ok "기존 허브 사용: ${C_B}$HUB · $HUBR${C_X}  (허브는 하나만 유지됩니다)"
  else
    note "허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션입니다."
    note "예) 허브에게 \"서버에 API 추가하고 웹에 버튼 달아줘\" 한 마디"
    note "    → 허브가 서버·웹 세션에 각각 시키고, 끝나면 결과를 모아 보고합니다."
    note "없어도 됩니다 — 세션끼리는 직접 대화 가능. 나중에 'tell hub'로 추가할 수 있습니다."
    ask "총괄 관리 세션을 만들까요? [y/N]: "; read -r MK
    if [ "$MK" = "y" ] || [ "$MK" = "Y" ]; then
      make_hub
    else
      skip "건너뜀 (나중에 추가: tell hub)"
    fi
  fi
  step "[2/2] 프로젝트 등록"
  note "프로젝트(세션) 하나에 역할(패널)을 여러 개 둘 수 있습니다. 예: 서버·웹·앱"
  while :; do
    echo ""
    ask "프로젝트 이름 = 세션 이름 (빈 값 = 완료): "; read -r S; [ -z "$S" ] && break
    while :; do
      echo ""
      note "· 패널 = 이 프로젝트에 상주할 Claude 하나 (예: 서버 / 웹 / 앱)"
      ask "  추가할 패널(역할) 이름 (빈 값 = 이 프로젝트 완료): "; read -r R; [ -z "$R" ] && break
      ask "  '$R' 담당 디렉터리: "; read -e -r D; D=$(abspath "$D")
      [ -z "$D" ] && { warn "디렉터리는 필수"; continue; }
      ask "  '$R' 모델 [엔터=$DEFAG · claude · codex]: "; read -r AG
      case "$AG" in codex) AG=codex ;; claude) AG=claude ;; *) AG="$DEFAG" ;; esac
      load_agent_profile "$AG"   # 규약 파일(CLAUDE.md/AGENTS.md)·대화 조회를 이 모델에 맞춤
      ask_resume_id "$D"
      echo "$S|$R|$D|$RID|$AG" >> "$WS_CONF"
      append_role_template "$D" "$S" "$R" "$HUB" "$HUBR"
      ok "패널 추가 완료 — ${C_B}$S · $R${C_X} ${C_D}($AG)${C_X}"
      note "계속 추가하려면 다음 패널 이름 입력 · 그만하려면 엔터(빈 값) 또는 Ctrl+C"
      note "────────────────────────────────────────"
    done
    ok "프로젝트 '$S' 구성 완료"
  done
  banner "완료"
  ok "저장: $WS_CONF"
  echo ""
  echo "${C_B}다음 단계:${C_X}"
  echo "  ${C_C}tell up --all${C_X}          # 허브·프로젝트 전부 켜기 (허브로 접속)"
  echo "  ${C_C}tell ws <프로젝트>${C_X}      # 하나만 띄우기 (패널 분할 + claude 자동 실행)"
  echo "  ${C_C}tell list${C_X}              # 말 걸 수 있는 주소 확인"
}

cmd_adopt() {
  banner "adopt · 쓰던 Claude 가져오기 (재시작 불필요)"
  command -v tmux >/dev/null 2>&1 || { warn "tmux 없음"; exit 1; }
  note "언제든 Ctrl+C 로 종료할 수 있습니다 — 그때까지 진행분은 저장됩니다."
  mkdir -p "$CONFIG_DIR"
  trap 'echo ""; ok "지금까지 진행분 저장됨: $WS_CONF   (확인: tell list)"; exit 0' INT
  local HAVE_TMUX=0; tmux ls >/dev/null 2>&1 && HAVE_TMUX=1
  step "[1/3] 총괄 관리(허브) 세션 — 선택사항"
  if get_hub; then # 허브는 하나만 — 이미 있으면 묻지 않는다
    ok "기존 허브 사용: ${C_B}$HUB · $HUBR${C_X}  (허브는 하나만 유지됩니다)"
  else
    note "허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션 — 일을 나눠 시키고 결과를 모아 보고."
    note "이미 허브로 쓰는 세션이 있으면 '세션 역할'로 지정 (예: hub hub). 없으면 그냥 엔터."
    ask "허브 지정 [엔터 = 건너뜀]: "; read -r HUB HUBR _junk
    HUBR=${HUBR:-$HUB}
    if [ -n "$HUB" ]; then
      echo "$HUB|$HUBR" > "$HUB_FILE"
      ok "허브 등록: ${C_B}$HUB · $HUBR${C_X}"
    else
      skip "건너뜀 (나중에 추가: tell hub)"
    fi
  fi
  step "[2/3] 떠 있는 패널 편입 — 각 패널(Claude)을 어떤 주소(역할)로 쓸지 정합니다"
  if [ "$HAVE_TMUX" = "1" ]; then
    tmux list-panes -a -F '#{session_name}|#{pane_id}|#{pane_title}|#{pane_current_path}' | while IFS='|' read -r S P T D; do
      echo ""
      echo "${C_B}▸ 프로젝트(세션) '$S' · 패널 \"$T\"${C_X}"
      note "  디렉터리: $D"
      ask "  이 Claude의 역할 이름? [엔터=\"$T\" 유지 / 새 이름 입력 / s=건너뜀]: "; read -r ANS </dev/tty
      [ "$ANS" = "s" ] && { skip "건너뜀"; continue; }
      ROLE=${ANS:-$T}
      [ "$ROLE" != "$T" ] && tmux select-pane -t "$P" -T "$ROLE"
      echo "$S|$ROLE|$D" >> "$WS_CONF"
      append_role_template "$D" "$S" "$ROLE" "$HUB" "$HUBR"
      ok "패널 편입 완료 — ${C_B}$S · $ROLE${C_X}"
      ask "  이 패널과 바로 연결 테스트(핑퐁)할까요? [y/N]: "; read -r GO </dev/tty
      if [ "$GO" = "y" ]; then
        "$0" "$S" "$ROLE" "연결 확인. CLAUDE.md를 Read로 다시 읽은 뒤, 받은 키로 tell -r 로 '퐁 정상' 한 줄만 응답해줘."
      fi
      note "────────────────────────────────────────"
    done
  else
    skip "떠 있는 세션 없음 — 건너뜀"
  fi
  step "[3/3] 터미널 탭에서 쓰던 대화 가져오기 — 선택사항"
  note "일반 터미널(분할 화면 밖)에서 쓰던 Claude 대화를 이어받아 패널로 만듭니다."
  note "세션ID만 있으면 됩니다 — 담당 디렉터리는 대화 기록에서 자동으로 찾습니다."
  while :; do
    echo ""
    ask "프로젝트 이름 = 세션 이름 (빈 값 = 완료): "; read -r S; [ -z "$S" ] && break
    ask "  이 Claude의 역할(패널) 이름: "; read -r R; [ -z "$R" ] && { warn "역할은 필수"; continue; }
    ask "  이어받을 대화 세션ID (모르면 엔터 — 디렉터리에서 찾아줌): "; read -r RID
    if [ -n "$RID" ]; then
      D=$(dir_from_session_id "$RID") || D=""
      if [ -n "$D" ]; then
        ok "담당 디렉터리 자동 감지: $D"
      else
        warn "세션ID '$RID'의 대화 기록을 못 찾음 — ID를 확인하거나 디렉터리를 직접 입력하세요"
        ask "  담당 디렉터리: "; read -e -r D; D=$(abspath "$D")
        [ -z "$D" ] && { warn "디렉터리는 필수"; continue; }
      fi
    else
      ask "  담당 디렉터리(그 대화를 쓰던 곳): "; read -e -r D; D=$(abspath "$D")
      [ -z "$D" ] && { warn "디렉터리는 필수"; continue; }
      ask_resume_id "$D"
      [ -z "$RID" ] && note "(이어받을 대화 없음 — 새 대화로 등록)"
    fi
    echo "$S|$R|$D|$RID" >> "$WS_CONF"
    append_role_template "$D" "$S" "$R" "$HUB" "$HUBR"
    ok "가져오기 완료 — ${C_B}$S · $R${C_X}${RID:+  (대화 $RID 이어받음)}"
  done
  banner "완료"
  ok "확인: ${C_C}tell list${C_X}   ·   띄우기: ${C_C}tell ws <프로젝트>${C_X}"
}

cmd_hub() {
  banner "hub · 총괄 관리 세션 추가"
  note "허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션입니다."
  note "예) 허브에게 \"서버에 API 추가하고 웹에 버튼 달아줘\" → 알아서 나눠 시키고 취합 보고."
  echo ""
  mkdir -p "$CONFIG_DIR"
  make_hub || exit 1
  echo ""
  echo "${C_B}다음:${C_X} ${C_C}tell ws $HUB${C_X}   ${C_D}(이후 init/adopt로 등록하는 프로젝트에 이 허브 주소가 연결됩니다)${C_X}"
}

cmd_list() {
  command -v tmux >/dev/null 2>&1 || { warn "tmux 없음"; exit 1; }
  tmux ls >/dev/null 2>&1 || { echo "떠 있는 tmux 세션 없음 — 'tell ws <세션>' 으로 띄우세요"; exit 0; }
  banner "list · 주소록"
  note "사용법: tell <세션> <역할> \"<메시지>\""
  echo ""
  printf "${C_B}%-16s %-16s %-6s %-8s %s${C_X}\n" "세션" "역할" "연결" "실행" "디렉터리"
  tmux list-panes -a -F '#{session_name}|#{pane_title}|#{pane_current_path}|#{pane_current_command}' \
  | while IFS='|' read -r S T D C; do
      # 규약 체크: Claude Code는 상위 폴더 CLAUDE.md도 상속하므로 조상 디렉터리까지 올라가며 확인
      conv="❌"; dir="$D"
      while [ -n "$dir" ] && [ "$dir" != "/" ]; do
        if [ -f "$dir/$AGENT_CONV" ] && grep -q '세션 요청 - KEY' "$dir/$AGENT_CONV" 2>/dev/null; then conv="✅"; break; fi
        dir=$(dirname "$dir")
      done
      case "$C" in claude|codex|node|[0-9]*.[0-9]*) run="$AGENT_CMD" ;; *) run="$C" ;; esac   # 에이전트 CLI는 버전 문자열로 보고되기도 함
      printf '%-16s %-16s %-6s %-8s %s\n' "$S" "$T" "$conv" "$run" "$D"
    done
  echo ""
  note "연결 ❌ = 아직 브릿지에 편입 안 된 패널 → 'tell adopt'로 편입하면 응답이 돌아옵니다."
}

remove_bridge_section() { # $1=dir — 규약 파일에서 자동 삽입된 규약 블록만 제거 (백업 .bak, 그 외 내용 보존)
  local f="$1/$AGENT_CONV"
  [ -f "$f" ] || return 1
  grep -q '<!-- claude-tell-bridge' "$f" || return 1
  cp "$f" "$f.bak"
  awk '/<!-- claude-tell-bridge/{skip=1} !skip{print} /<!-- \/claude-tell-bridge -->/{skip=0}' "$f.bak" > "$f"
  grep -q '[^[:space:]]' "$f" || rm -f "$f"   # 우리 블록뿐이었다면 빈 파일 정리
  return 0
}

cmd_rm() { # 워크스페이스 삭제 — 종료 + 설정 제거 + 규약 블록 제거 (프로젝트 파일은 무손상)
  local NAME="${1:-}"
  if [ -z "$NAME" ]; then
    banner "rm · 워크스페이스 삭제"
    echo "usage: ${C_B}tell rm <세션>${C_X}   ${C_D}(끄기만 하려면: tell down <세션>)${C_X}"
    if [ -f "$WS_CONF" ]; then
      step "설정된 워크스페이스"; grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | awk '!seen[$0]++'
    fi
    exit 2
  fi
  banner "rm · '$NAME' 워크스페이스 삭제"
  local IN_CONF=0 RUNNING=0
  [ -f "$WS_CONF" ] && LC_ALL=C awk -F'|' -v s="$NAME" '$1==s{f=1} END{exit !f}' "$WS_CONF" && IN_CONF=1
  tmux has-session -t "=$NAME" 2>/dev/null && RUNNING=1
  if [ "$IN_CONF" = 0 ] && [ "$RUNNING" = 0 ]; then warn "'$NAME' — 설정에도 없고 실행 중도 아님"; exit 1; fi
  note "삭제될 것:"
  [ "$RUNNING" = 1 ] && note "  · 실행 중 세션 종료 (진행 중 대화 닫힘)"
  [ "$IN_CONF" = 1 ] && note "  · workspaces.conf 등록 제거"
  [ "$IN_CONF" = 1 ] && note "  · 담당 디렉터리 CLAUDE.md의 브릿지 규약 블록 제거"
  get_hub && [ "$HUB" = "$NAME" ] && note "  · 허브 지정 해제"
  note "  ${C_B}프로젝트 파일·코드는 건드리지 않습니다${C_X}"
  ask "진행할까요? [y/N]: "; read -r A
  { [ "$A" = "y" ] || [ "$A" = "Y" ]; } || { skip "취소됨"; exit 0; }
  [ "$RUNNING" = 1 ] && tmux kill-session -t "=$NAME" && ok "세션 종료됨"
  if [ "$IN_CONF" = 1 ]; then
    local DIRS D
    DIRS=$(grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | LC_ALL=C awk -F'|' -v s="$NAME" '$1==s{print $3}' | sort -u)
    cp "$WS_CONF" "$WS_CONF.bak"
    LC_ALL=C awk -F'|' -v s="$NAME" '$1!=s' "$WS_CONF.bak" > "$WS_CONF"
    ok "설정에서 제거됨 ${C_D}(백업: $WS_CONF.bak)${C_X}"
    while IFS= read -r D; do
      [ -n "$D" ] || continue
      D=${D/#\~/$HOME}
      if grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | LC_ALL=C awk -F'|' -v d="$D" '$3==d{f=1} END{exit !f}'; then
        skip "규약 유지: $D (다른 세션이 같은 디렉터리 사용 중)"
      elif remove_bridge_section "$D"; then
        ok "규약 제거: $D/$AGENT_CONV ${C_D}(백업 .bak)${C_X}"
      fi
    done <<EOF
$DIRS
EOF
  fi
  if get_hub && [ "$HUB" = "$NAME" ]; then
    rm -f "$HUB_FILE"
    ok "허브 해제됨 — 새 허브 등록: ${C_C}tell hub${C_X}"
  fi
  return 0
}

cmd_down() { # 끄기 — tmux 세션 종료만, 설정은 유지 (반대: tell up)
  local T="${1:-}"
  banner "down · 끄기"
  if [ -z "$T" ]; then
    echo "usage: ${C_B}tell down <세션>${C_X} 또는 ${C_B}tell down --all${C_X}   ${C_D}(설정은 유지 — 완전 삭제는 tell rm)${C_X}"
    step "실행 중 세션"; tmux ls 2>/dev/null || note "(없음)"
    exit 2
  fi
  case "$T" in
    --all|-all|all)
      if [ ! -f "$WS_CONF" ]; then warn "설정 없음: $WS_CONF"; exit 1; fi
      local NAMES S RUN=""
      NAMES=$(grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | awk '!seen[$0]++')
      while IFS= read -r S; do
        [ -n "$S" ] && tmux has-session -t "=$S" 2>/dev/null && RUN="$RUN$S
"
      done <<EOF
$NAMES
EOF
      if [ -z "$RUN" ]; then note "떠 있는 설정 세션이 없습니다"; exit 0; fi
      echo "종료 대상 (설정된 세션만 — 그 외 tmux 세션은 안 건드림):"
      printf '%s' "$RUN" | sed 's/^/  · /'
      ask "전부 종료할까요? 진행 중 대화가 닫힙니다 [y/N]: "; read -r A
      { [ "$A" = "y" ] || [ "$A" = "Y" ]; } || { skip "취소됨"; exit 0; }
      while IFS= read -r S; do
        [ -n "$S" ] && tmux kill-session -t "=$S" 2>/dev/null && ok "$S 종료"
      done <<EOF
$RUN
EOF
      note "다시 켜기: ${C_C}tell up${C_X}"
      ;;
    *)
      tmux has-session -t "=$T" 2>/dev/null || { warn "실행 중 아님: $T"; exit 1; }
      local n; n=$(tmux list-panes -t "=$T" 2>/dev/null | wc -l | tr -d ' ')
      # ${n}개: 변수 뒤에 한글이 바로 붙으면 macOS bash 3.2가 변수명을 잘못 파싱함 — 중괄호 필수
      ask "'$T'(패널 ${n}개)를 종료할까요? 진행 중 대화가 닫힙니다 [y/N]: "; read -r A
      if [ "$A" = "y" ] || [ "$A" = "Y" ]; then
        tmux kill-session -t "=$T" && ok "$T 종료 — 다시 켜기: ${C_C}tell up $T${C_X}"
      else
        skip "취소됨"
      fi
      ;;
  esac
}

ws_boot() { # $1=세션 — 설정대로 부트스트랩(패널 분할·제목·claude 실행). 이미 떠 있으면 그대로 0
  local NAME="$1" p=""
  tmux has-session -t "=$NAME" 2>/dev/null && return 0
  # 주의: 루프 안 tmux 호출에 </dev/null — stdin(설정 라인)을 삼켜 다음 패널을 건너뛰는 버그 방지
  grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | LC_ALL=C awk -F'|' -v s="$NAME" '$1==s' | while IFS='|' read -r S R D RID AG; do
    D=${D/#\~/$HOME}
    if [ ! -d "$D" ]; then echo "⚠️ 디렉터리 없음: $D (건너뜀)"; continue; fi
    if ! tmux has-session -t "=$NAME" 2>/dev/null; then
      p=$(tmux new-session -d -P -F '#{pane_id}' -s "$NAME" -c "$D" </dev/null)
    else
      # split 타깃은 세션명이 아니라 패널이어야 함 → 직전 패널 id 사용
      p=$(tmux split-window -h -P -F '#{pane_id}' -t "$p" -c "$D" </dev/null)
    fi
    tmux select-pane -t "$p" -T "$R" </dev/null
    # 4번째=대화 세션ID(이어받기) · 5번째=에이전트(패널별 claude/codex). exec로 셸 대체(종료 시 패널 정리)
    tmux send-keys -t "$p" "$(agent_launch "${AG:-$TELL_AGENT}" "${RID:-}")" Enter </dev/null
  done
  tmux has-session -t "=$NAME" 2>/dev/null || return 1
  tmux select-layout -t "=$NAME" tiled 2>/dev/null
  return 0
}

LAYOUT_PRESETS="tiled main-vertical main-horizontal even-horizontal even-vertical"
cmd_layout() { # 패널 배치 변경 — tmux.conf 편집 없이 프리셋으로. tell layout [<세션>] <프리셋>
  local a1="${1:-}" a2="${2:-}" NAME PRESET
  if [ -z "$a1" ]; then
    banner "layout · 패널 배치"
    echo "usage: ${C_B}tell layout [<세션>] <프리셋>${C_X}"
    note "프리셋: $LAYOUT_PRESETS"
    note "세션 생략 시 현재 세션(패널 안에서 실행할 때)"
    exit 2
  fi
  if [ -n "$a2" ]; then NAME="$a1"; PRESET="$a2"
  else
    PRESET="$a1"   # 세션 생략 → 현재 세션 자동 감지
    [ -n "${TMUX_PANE:-}" ] && NAME=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null)
    [ -z "${NAME:-}" ] && { warn "세션을 지정하세요: tell layout <세션> <프리셋>"; exit 2; }
  fi
  case " $LAYOUT_PRESETS " in *" $PRESET "*) ;; *) warn "알 수 없는 프리셋: $PRESET"; note "가능: $LAYOUT_PRESETS"; exit 2 ;; esac
  tmux has-session -t "=$NAME" 2>/dev/null || { warn "실행 중 세션 아님: $NAME"; exit 1; }
  # select-layout -t는 target-window라 '=세션:'처럼 콜론으로 윈도우를 명시해야 함('=세션'만 주면 pane으로 오해)
  tmux select-layout -t "=$NAME:" "$PRESET" >/dev/null 2>&1 && ok "$NAME → ${C_B}$PRESET${C_X}" || { warn "레이아웃 적용 실패"; exit 1; }
}

cmd_completion() { # 셸 자동완성 스크립트 출력 — .zshrc/.bashrc에: eval "$(tell completion)"
  cat <<'EOS'
# claude-tell-bridge 자동완성 (bash/zsh) — eval "$(tell completion)"
if [ -n "${ZSH_VERSION:-}" ]; then
  autoload -U +X compinit bashcompinit
  whence -w compdef >/dev/null 2>&1 || compinit -u 2>/dev/null
  bashcompinit
fi
_tell_conf() { printf '%s' "${TELL_CONFIG_DIR:-$HOME/.config/claude-tell-bridge}/workspaces.conf"; }
_tell_sessions() {
  local conf; conf=$(_tell_conf)
  { tmux list-sessions -F '#{session_name}' 2>/dev/null
    [ -f "$conf" ] && grep -vE '^[[:space:]]*(#|$)' "$conf" | cut -d'|' -f1
  } | sort -u
}
_tell_roles() { # $1=세션 — 떠 있는 패널 제목 + 설정된 역할
  local conf; conf=$(_tell_conf)
  { tmux list-panes -t "=$1" -F '#{pane_title}' 2>/dev/null
    [ -f "$conf" ] && LC_ALL=C awk -F'|' -v s="$1" '$1==s{print $2}' "$conf"
  } | sort -u
}
_tell() {
  local cur="${COMP_WORDS[COMP_CWORD]}" idx=1
  [ "${COMP_WORDS[1]:-}" = "-r" ] && idx=3   # -r <KEY> 만큼 위치가 밀림
  local pos=$((COMP_CWORD - idx + 1)) first="${COMP_WORDS[$idx]:-}"
  COMPREPLY=()
  local LAYOUTS="tiled main-vertical main-horizontal even-horizontal even-vertical"
  if [ "$pos" -eq 1 ]; then
    COMPREPLY=($(compgen -W "$(_tell_sessions) init adopt hub up down layout ws list rm doctor completion help -r" -- "$cur"))
  elif [ "$pos" -eq 2 ]; then
    case "$first" in
      ws|rm) COMPREPLY=($(compgen -W "$(_tell_sessions)" -- "$cur")) ;;
      up) COMPREPLY=($(compgen -W "$(_tell_sessions) --all --tabs" -- "$cur")) ;;
      down) COMPREPLY=($(compgen -W "$(_tell_sessions) --all" -- "$cur")) ;;
      layout) COMPREPLY=($(compgen -W "$(_tell_sessions) $LAYOUTS" -- "$cur")) ;;
      init|adopt|hub|list|doctor|completion|help|-r) ;;
      *) COMPREPLY=($(compgen -W "$(_tell_roles "$first")" -- "$cur")) ;;
    esac
  elif [ "$pos" -eq 3 ] && [ "$first" = "layout" ]; then
    COMPREPLY=($(compgen -W "$LAYOUTS" -- "$cur"))
  fi
}
complete -F _tell tell loomo
EOS
  # 터미널에서 직접 실행했을 때만 적용법 안내 (eval로 캡처될 땐 stdout이 tty가 아니므로 침묵)
  [ -t 1 ] && echo "# 적용: echo 'eval \"\$(tell completion)\"' >> ~/.zshrc  (bash는 ~/.bashrc)" >&2
  return 0
}

cmd_ws() {
  local NAME="${1:-}"
  if [ ! -f "$WS_CONF" ]; then echo "설정 없음: $WS_CONF — 'tell init' 먼저"; exit 1; fi
  if [ -z "$NAME" ]; then
    echo "── 실행 중 ──"; tmux ls 2>/dev/null || echo "(없음)"
    echo "── 설정된 워크스페이스 ──"
    grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | sort -u
    exit 0
  fi
  ws_boot "$NAME" || { echo "알 수 없는 워크스페이스: $NAME"; exit 1; }
  if [ -n "${TMUX:-}" ]; then tmux switch-client -t "=$NAME"; else tmux attach -t "=$NAME"; fi
}

open_terminal_tab() { # $1=세션 — macOS 터미널 앱에 그 세션으로 접속하는 탭/창을 연다
  # 작은따옴표: AppleScript 문자열(큰따옴표)과 충돌하지 않게
  local cmd="tmux attach -t '=$1'"
  [ "$(uname)" = "Darwin" ] || { warn "--tabs 는 macOS에서만 지원"; return 1; }
  if [ "${TERM_PROGRAM:-}" = "iTerm.app" ] || osascript -e 'application "iTerm2" is running' 2>/dev/null | grep -q true; then
    osascript >/dev/null <<EOF
tell application "iTerm2"
  activate
  if (count of windows) = 0 then
    create window with default profile
  else
    tell current window to create tab with default profile
  end if
  tell current session of current window to write text "$cmd"
end tell
EOF
  else
    # Terminal.app: 새 탭 = Cmd+T 키 입력(System Events) — '손쉬운 사용' 권한 필요. 실패 시 새 창 폴백
    if osascript >/dev/null 2>&1 <<EOF
tell application "Terminal" to activate
tell application "System Events" to keystroke "t" using command down
delay 0.3
tell application "Terminal" to do script "$cmd" in selected tab of front window
EOF
    then :; else
      if [ "${TERMTAB_WARNED:-0}" = "0" ]; then
        TERMTAB_WARNED=1
        warn "탭 열기 실패 → 새 창으로 엽니다. 탭을 원하면 방금 열린 설정에서 '터미널'을 허용하세요"
        # 앱 권한 요청 UX 흉내: 손쉬운 사용 설정 화면을 바로 열어준다 (권한 부여 자체는 사용자만 가능)
        open "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility" 2>/dev/null
      fi
      osascript >/dev/null <<EOF
tell application "Terminal"
  activate
  do script "$cmd"
end tell
EOF
    fi
  fi
}

cmd_up() { # 켜기 — <세션>: 하나만 / --all: 전부 켜고 허브 접속 / 인자 없음: 무엇을 켤지 안내 (실수로 전체 켜짐 방지)
  local TABS=0 ONLY="" ALL=0 a
  for a in "$@"; do
    case "$a" in
      -t|--tabs) TABS=1 ;;
      --all|-all|all) ALL=1 ;;
      *) ONLY="$a" ;;
    esac
  done
  if [ ! -f "$WS_CONF" ]; then echo "설정 없음: $WS_CONF — 'tell init' 먼저"; exit 1; fi
  if [ -z "$ONLY" ] && [ "$ALL" = "0" ]; then # 인자 없음 → 켜지 말고 무엇을 켤지 안내
    banner "up · 무엇을 켤까"
    step "설정된 프로젝트"
    grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | awk '!seen[$0]++' | while IFS= read -r s; do
      [ -n "$s" ] || continue
      if tmux has-session -t "=$s" 2>/dev/null; then echo "  ${C_G}● $s${C_X} ${C_D}(떠 있음)${C_X}"; else echo "  ${C_D}○ $s${C_X}"; fi
    done
    echo ""
    note "하나만 켜기:  ${C_C}${BRAND} up <프로젝트>${C_X}"
    note "전체 켜기:    ${C_C}${BRAND} up --all${C_X}   ${C_D}(+ --tabs 로 세션별 터미널 탭)${C_X}"
    exit 0
  fi
  if [ -n "$ONLY" ]; then # 하나만 켜기 (백그라운드 — 접속은 tell ws)
    banner "up · '$ONLY' 켜기"
    if tmux has-session -t "=$ONLY" 2>/dev/null; then
      skip "$ONLY — 이미 떠 있음"
    elif ws_boot "$ONLY"; then
      ok "$ONLY 켜짐 (백그라운드)"
    else
      warn "알 수 없는 워크스페이스: $ONLY (목록: tell ws)"; exit 1
    fi
    if [ "$TABS" = "1" ]; then open_terminal_tab "$ONLY" && ok "열림: $ONLY"; else note "접속: tell ws $ONLY"; fi
    exit 0
  fi
  banner "up · 전체 켜기"
  local NAMES; NAMES=$(grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | awk '!seen[$0]++')
  [ -n "$NAMES" ] || { warn "설정된 세션 없음 — 'tell init' 먼저"; exit 1; }
  local S
  while IFS= read -r S; do
    if tmux has-session -t "=$S" 2>/dev/null; then
      skip "$S — 이미 떠 있음"
    elif ws_boot "$S"; then
      ok "$S 켜짐"
    else
      warn "$S 부트 실패 (디렉터리 확인: tell ws $S)"
    fi
  done <<EOF
$NAMES
EOF
  local TARGET=""
  get_hub && tmux has-session -t "=$HUB" 2>/dev/null && TARGET="$HUB"
  [ -z "$TARGET" ] && TARGET=$(printf '%s\n' "$NAMES" | head -1)
  echo ""
  if [ "$TABS" = "1" ]; then # 세션마다 터미널 탭 — 허브는 마지막(=포커스)에
    while IFS= read -r S; do
      [ "$S" = "$TARGET" ] && continue
      tmux has-session -t "=$S" 2>/dev/null || continue
      open_terminal_tab "$S" && ok "열림: $S"
    done <<EOF
$NAMES
EOF
    open_terminal_tab "$TARGET" && { if [ "$TARGET" = "${HUB:-}" ]; then ok "열림: $TARGET (허브·포커스)"; else ok "열림: $TARGET (포커스)"; fi; }
    exit 0
  fi
  if [ "$TARGET" = "${HUB:-}" ]; then ok "접속: $TARGET (허브)"; else ok "접속: $TARGET"; fi
  if [ -n "${TMUX:-}" ]; then tmux switch-client -t "=$TARGET"; else tmux attach -t "=$TARGET"; fi
}

case "${1:-}" in
  init)   shift; cmd_init "$@";   exit $? ;;
  adopt)  shift; cmd_adopt "$@";  exit $? ;;
  hub)    shift; cmd_hub "$@";    exit $? ;;
  up)     shift; cmd_up "$@";     exit $? ;;
  down)   shift; cmd_down "$@";   exit $? ;;
  layout) shift; cmd_layout "$@"; exit $? ;;
  completion) shift; cmd_completion; exit $? ;;
  help|--help|-h) cmd_help;       exit 0 ;;
  "")     cmd_help;               exit 2 ;;   # 인자 없이 실행 → 도움말
  list)   shift; cmd_list;        exit $? ;;
  rm)     shift; cmd_rm "${1:-}"; exit $? ;;
  ws)     shift; cmd_ws "${1:-}"; exit $? ;;
  doctor) shift; cmd_doctor;      exit $? ;;
esac

# ══════════════════════════════════════════════════════════════════════════════
# 코어: 메시지 전송
# ══════════════════════════════════════════════════════════════════════════════

REPLY=0; KEY=""
if [ "${1:-}" = "-r" ]; then
  REPLY=1; KEY="${2:-}"; shift 2 2>/dev/null
  if [ -z "$KEY" ]; then echo "usage: tell -r <KEY> <세션> <역할> <메시지>"; exit 2; fi
fi

SESSION="${1:-}"; ROLE="${2:-}"; shift 2 2>/dev/null; MSG="$*"
if [ -z "$SESSION" ] || [ -z "$ROLE" ] || [ -z "$MSG" ]; then
  echo "usage: tell [-r <KEY>] <세션> <역할> \"<메시지>\""
  echo "       전체 명령·설명: tell help"
  exit 2
fi

# LC_ALL=C: macOS awk가 일부 로케일에서 비ASCII 문자열 == 비교를 깨뜨리는 버그 회피(바이트 단위 비교)
PANE=$(tmux list-panes -t "=$SESSION" -F "#{pane_id}	#{pane_title}" 2>/dev/null \
  | LC_ALL=C awk -F'\t' -v r="$ROLE" '$2==r{print $1; exit}')
if [ -z "$PANE" ]; then
  echo "[tell] 대상 패널 없음: $SESSION:$ROLE"
  echo "       (가용) $(tmux list-panes -t "=$SESSION" -F '#{pane_title}' 2>/dev/null | paste -sd' ' -)"
  exit 1
fi

# 대상 패널의 에이전트 프로필 로드 → 입력창 프롬프트 감지를 그 에이전트(claude=❯ / codex=›)에 맞춤
load_agent_profile "$(agent_of "$SESSION" "$ROLE")"

# 발신자(세션/역할) 자동 감지 — 받는 쪽이 '어디로 tell -r 할지' 알게 하는 핵심
SRC=""
if [ -n "${TMUX_PANE:-}" ]; then
  src_ses=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null)
  src_role=$(tmux display-message -p -t "$TMUX_PANE" '#{pane_title}' 2>/dev/null)
  [ -n "$src_ses" ] && [ -n "$src_role" ] && SRC=" from ${src_ses}/${src_role}"
fi

if [ "$REPLY" = "1" ]; then
  MSG="[세션 응답 - $KEY$SRC] $MSG"
else
  KEY=$(openssl rand -hex 3 2>/dev/null)
  [ -z "$KEY" ] && KEY=$(printf '%06x' $(( ((RANDOM<<8) ^ RANDOM) & 0xffffff )))
  MSG="[세션 요청 - $KEY$SRC] $MSG"
fi

# 입력창 미제출 텍스트(사용자 타이핑) 감지 → 덮어쓰기 방지 대기
has_unsubmitted_input() {
  local line
  line=$(tmux capture-pane -t "$PANE" -p 2>/dev/null | grep -E "^$AGENT_PROMPT" | tail -1 | sed -E "s/^$AGENT_PROMPT[[:space:]]*//; s/[[:space:]]+\$//")
  [ -n "$line" ] && return 0
  return 1
}
# codex는 빈 입력창에 회색 placeholder가 있어 미제출로 오인됨 → 감지 스킵(아래 prime이 어차피 비움)
if [ "$AGENT_CMD" != "codex" ]; then
  for i in 1 2 3; do
    has_unsubmitted_input || break
    echo "[tell] 입력창에 미제출 텍스트 감지 — 10초 후 재시도 ($i/3)"
    sleep 10
  done
fi

# codex TUI는 첫 입력 시 앞부분(헤더·KEY)을 놓친다 → 공백 하나로 입력창을 깨우고 C-u로 비운 뒤 본문 전송
if [ "$AGENT_CMD" = "codex" ]; then
  tmux send-keys -t "$PANE" Space; sleep 0.3
  tmux send-keys -t "$PANE" C-u;   sleep 0.2
fi
tmux send-keys -t "$PANE" -l "$MSG"
sleep 0.6
tmux send-keys -t "$PANE" Enter
sleep 0.8
head="$(printf '%s' "$MSG" | cut -c1-14)"
if tmux capture-pane -t "$PANE" -p 2>/dev/null | grep -qF "$AGENT_PROMPT $head"; then
  tmux send-keys -t "$PANE" Enter
fi

if [ "$REPLY" = "1" ]; then
  echo "[tell] 응답 전송 완료 → $SESSION:$ROLE ($PANE)  (KEY=$KEY)"
else
  echo "[tell] 요청 전송 완료 → $SESSION:$ROLE ($PANE)"
  echo "[tell] 요청 KEY=$KEY  ← 이 KEY의 [세션 응답 - $KEY] 를 기다리세요"
fi
