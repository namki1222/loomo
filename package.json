{
  "name": "@namki1222/loomo",
  "version": "1.1.0",
  "description": "Weave your Claude Code & Codex sessions into a team that talks to each other — multi-agent messaging over tmux, no daemon, no MCP.",
  "bin": {
    "loomo": "bin/tell",
    "tell": "bin/tell"
  },
  "files": [
    "bin",
    "templates",
    "README.md",
    "README.ko.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "preferGlobal": true,
  "keywords": [
    "loomo",
    "claude",
    "claude-code",
    "codex",
    "codex-cli",
    "tmux",
    "multi-agent",
    "agent-orchestration",
    "ai-agents",
    "session-to-session",
    "terminal",
    "orchestration",
    "cli",
    "messaging"
  ],
  "author": "namki1222",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namki1222/loomo.git"
  },
  "scripts": {
    "test": "bash -n bin/tell && echo syntax-ok"
  }
}
